{{#> base }}
{{> AppSidebar/sidebar components-modals=this }}
<div class="app-main__outer">
    <div class="app-main__inner">
        {{> AppMain/page-title }}

        <!-- ── Tipo 1: Modal con acciones / Informativo ─────────────────── -->
        <div class="row">
            <div class="col-md-12">
                <div class="main-card mb-3 card">
                    <div class="card-body">
                        <h5 class="card-title">Modal con acciones / Informativo</h5>
                        <p class="text-muted mb-3">
                            Header y footer con fondo <code>$gray-100</code> (#eaeef2).
                            Usar <code>.modal--action</code> en <code>.modal-dialog</code>.
                            Agregar <code>.modal-action-size</code> para ancho 900px en desktop.
                        </p>
                        <!-- Desktop (900px) -->
                        <button type="button" class="btn btn-primary mr-2 mb-2"
                            data-toggle="modal" data-target="#modalActionDesktop">
                            <span class="material-symbols-rounded btn-icon-ms">desktop_windows</span> Desktop (900px)
                        </button>
                        <!-- Móvil -->
                        <button type="button" class="btn btn-secondary mr-2 mb-2"
                            data-toggle="modal" data-target="#modalActionMobile">
                            <span class="material-symbols-rounded btn-icon-ms">smartphone</span> Móvil (sm)
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Tipo 2: Modal de confirmación ─────────────────────────────── -->
        <div class="row">
            <div class="col-md-12">
                <div class="main-card mb-3 card">
                    <div class="card-body">
                        <h5 class="card-title">Modal de confirmación</h5>
                        <p class="text-muted mb-3">
                            Todo fondo blanco (<code>$white</code>). Body con más espacio inferior.
                            Usar <code>.modal--confirm</code> en <code>.modal-dialog</code>.
                            El ancho por defecto de Bootstrap (500px) ya corresponde al desktop.
                            En móvil agregar <code>.modal-sm</code>.
                        </p>
                        <!-- Desktop (500px default) -->
                        <button type="button" class="btn btn-primary mr-2 mb-2"
                            data-toggle="modal" data-target="#modalConfirmDesktop">
                            <span class="material-symbols-rounded btn-icon-ms">desktop_windows</span> Desktop (500px)
                        </button>
                        <!-- Móvil (sm) -->
                        <button type="button" class="btn btn-secondary mr-2 mb-2"
                            data-toggle="modal" data-target="#modalConfirmMobile">
                            <span class="material-symbols-rounded btn-icon-ms">smartphone</span> Móvil (sm)
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div>
    {{> AppFooter/footer }}
</div>
{{/ base }}


<!-- ════════════════════════════════════════════════════════════════════════ -->
<!-- Modal con acciones — Desktop (900px)                                    -->
<!-- .modal-dialog: .modal--action .modal-action-size                        -->
<!-- ════════════════════════════════════════════════════════════════════════ -->
<div class="modal fade" id="modalActionDesktop" tabindex="-1" role="dialog"
    aria-labelledby="modalActionDesktopLabel" aria-hidden="true">
    <div class="modal-dialog modal--action modal-action-size" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalActionDesktopLabel">Titular</h5>
                <button type="button" class="icon-btn icon-btn--tertiary icon-btn--sm" data-dismiss="modal" aria-label="Cerrar">
                    <span class="material-symbols-rounded">close</span>
                </button>
            </div>
            <div class="modal-body">
                <p class="mb-0">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nunc pulvinar,
                    elit vel mattis iaculis, purus quam tristique magna, in ornare nulla lectus ac tortor.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">
                    <span class="material-symbols-rounded btn-icon-ms">close</span> Cancelar
                </button>
                <button type="button" class="btn btn-primary">
                    <span class="material-symbols-rounded btn-icon-ms">settings</span> Acción principal
                </button>
            </div>
        </div>
    </div>
</div>


<!-- ════════════════════════════════════════════════════════════════════════ -->
<!-- Modal con acciones — Móvil (modal-sm, título 16px)                      -->
<!-- .modal-dialog: .modal--action .modal--mobile .modal-sm                  -->
<!-- ════════════════════════════════════════════════════════════════════════ -->
<div class="modal fade" id="modalActionMobile" tabindex="-1" role="dialog"
    aria-labelledby="modalActionMobileLabel" aria-hidden="true">
    <div class="modal-dialog modal--action modal--mobile modal-sm" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title" id="modalActionMobileLabel">Titular</h6>
                <button type="button" class="icon-btn icon-btn--tertiary icon-btn--sm" data-dismiss="modal" aria-label="Cerrar">
                    <span class="material-symbols-rounded">close</span>
                </button>
            </div>
            <div class="modal-body">
                <p class="mb-0">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nunc pulvinar,
                    elit vel mattis iaculis, purus quam tristique magna, in ornare nulla lectus ac tortor.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">
                    <span class="material-symbols-rounded btn-icon-ms">close</span> Cancelar
                </button>
                <button type="button" class="btn btn-primary btn-sm">
                    <span class="material-symbols-rounded btn-icon-ms">settings</span> Acción principal
                </button>
            </div>
        </div>
    </div>
</div>


<!-- ════════════════════════════════════════════════════════════════════════ -->
<!-- Modal de confirmación — Desktop (500px default)                         -->
<!-- .modal-dialog: .modal--confirm                                          -->
