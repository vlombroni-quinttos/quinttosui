<!-- Badge: total real de filas en runtime -->
<script>
  (function () {
    var rows  = document.querySelectorAll('#preceptor-cursos-body tr');
    var badge = document.getElementById('preceptor-cursos-count');
    if (badge) badge.textContent = rows.length;
  })();
</script>

