        <!-- ═══════════════════════════════════════════════════════════════
             Widget Card: Mis Cursos — Home Preceptor
             Componente: dwc (Dashboard Widget Card)
             Diferencias vs. Home Docente:
               · Badge info (azul) → dwc-badge--info
               · Enlace "Ver todos" en header-right
               · Sin fila de filtros
             ═══════════════════════════════════════════════════════════ -->
                    <div class="main-card mb-3 card dwc">

                        <!-- ── Header ──────────────────────────────────────────── -->
                        <div class="card-header">
                            <div class="dwc-header-left">
                                <span class="dwc-title">Mis Cursos</span>
                                <span class="dwc-badge dwc-badge--info" id="preceptor-cursos-count">—</span>
                            </div>
                            <div class="dwc-header-right ml-auto">
                                <a href="#" class="dwc-link-action">Ver todos</a>
                            </div>
                        </div>

                        <!-- ── Toolbar: solo buscador ──────────────────────────── -->
                        <div class="dwc-table-tools">
                            <div class="dwc-search-wrap">
                                <span class="material-symbols-rounded">search</span>
                                <input type="text" class="dwc-table-search" placeholder="Buscar">
                            </div>
                        </div>

                        <!-- ── Tabla con scroll (~5 filas visibles) ────────────── -->
