{{#> base }}
{{> AppSidebar/sidebar forms-controls=this }}
<div class="app-main__outer">
    <div class="app-main__inner">
        {{> AppMain/page-title }}
        <ul class="tab-nav nav" role="tablist">
            <li class="nav-item">
                <a role="tab" class="nav-link active" id="tab-0" data-toggle="tab" href="#tab-content-0">Basic</a>
            </li>
            <li class="nav-item">
                <a role="tab" class="nav-link" id="tab-1" data-toggle="tab" href="#tab-content-1">Input Groups</a>
            </li>
            <li class="nav-item">
                <a role="tab" class="nav-link" id="tab-2" data-toggle="tab" href="#tab-content-2">Custom Controls</a>
            </li>
        </ul>
        <div class="tab-content">
            <div class="tab-pane tabs-animation fade show active" id="tab-content-0" role="tabpanel">
                <div class="row">
                    <div class="col-md-6">
                        <div class="main-card mb-3 card">
                            <div class="card-body">
                                <h5 class="card-title">Controls Types</h5>
                                <form class="">
                                    <div class="position-relative form-group">
                                        <label for="exampleEmail" class="">Email</label>
                                        <input name="email" id="exampleEmail" placeholder="with a placeholder" type="email" class="form-control">
                                    </div>
                                    <div class="position-relative form-group">
                                        <label for="examplePassword" class="">Password</label>
                                        <input name="password" id="examplePassword" placeholder="password placeholder" type="password" class="form-control">
                                    </div>
                                    <div class="position-relative form-group">
                                        <label class="">Select</label>
                                        <div class="dropdown tpl-select">
                                            <button type="button" class="form-control tpl-select__trigger" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                <span class="tpl-select__value tpl-select__value--ph">Seleccioná una opción</span>
                                                <span class="material-symbols-rounded tpl-select__chevron">arrow_drop_down</span>
                                            </button>
                                            <div class="dropdown-menu tpl-select__menu">
                                                <button type="button" class="dropdown-item tpl-select__item" data-value="1">1</button>
                                                <button type="button" class="dropdown-item tpl-select__item" data-value="2">2</button>
                                                <button type="button" class="dropdown-item tpl-select__item" data-value="3">3</button>
                                                <button type="button" class="dropdown-item tpl-select__item" data-value="4">4</button>
                                                <button type="button" class="dropdown-item tpl-select__item" data-value="5">5</button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="position-relative form-group">
                                        <div class="select-multiple">
                                            <div class="select-multiple__label">Select Multiple</div>
                                            <div class="select-multiple__trigger">
                                                <span class="select-multiple__placeholder" data-placeholder="Seleccioná una opción">Seleccioná una opción</span>
                                                <span class="select-multiple__arrow"><span class="material-symbols-rounded">arrow_drop_down</span></span>
                                            </div>
                                            <div class="select-multiple__dropdown">
                                                <div class="select-multiple__item">
                                                    <span class="select-multiple__checkbox"><span class="material-symbols-rounded">check</span></span>
                                                    <span class="select-multiple__item-label">1</span>
                                                </div>
                                                <div class="select-multiple__item">
                                                    <span class="select-multiple__checkbox"><span class="material-symbols-rounded">check</span></span>
                                                    <span class="select-multiple__item-label">2</span>
                                                </div>
                                                <div class="select-multiple__item">
                                                    <span class="select-multiple__checkbox"><span class="material-symbols-rounded">check</span></span>
                                                    <span class="select-multiple__item-label">3</span>
                                                </div>
                                                <div class="select-multiple__item">
                                                    <span class="select-multiple__checkbox"><span class="material-symbols-rounded">check</span></span>
                                                    <span class="select-multiple__item-label">4</span>
                                                </div>
                                                <div class="select-multiple__item">
                                                    <span class="select-multiple__checkbox"><span class="material-symbols-rounded">check</span></span>
                                                    <span class="select-multiple__item-label">5</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="position-relative form-group">
                                        <label for="exampleText" class="">Text Area</label>
                                        <textarea name="text" id="exampleText" class="form-control"></textarea>
                                    </div>
                                    <div class="position-relative form-group">
                                        <label class="">File</label>
                                        <div class="d-flex align-items-center gap-2" style="gap:12px;">
                                            <input name="file" id="exampleFile" type="file" class="d-none" onchange="document.getElementById('exampleFileName').textContent = this.files.length ? this.files[0].name : 'Sin archivos seleccionados'">
                                            <label for="exampleFile" class="btn-badge mb-0">
                                                <span class="material-symbols-rounded">attach_file</span>
                                                Adjuntar archivo
                                            </label>
                                            <span id="exampleFileName" class="form-text text-muted mb-0" style="font-size:.875rem;">Sin archivos seleccionados</span>
                                        </div>
                                        <small class="form-text text-muted mt-2">This is some placeholder block-level help
                                            text for the above input. It's a bit lighter and easily wraps to a new
                                            line.
                                        </small>
                                    </div>
                                    <div class="d-flex justify-content-end mt-3">
                                        <button type="submit" class="btn btn-primary">Submit</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="main-card mb-3 card">
                            <div class="card-body">
                                <h5 class="card-title">Sizing</h5>
                                <form class="">
                                    <input placeholder="default" type="text" class="mb-2 form-control">
                                    <input placeholder="sm" type="text" class="mb-2 form-control-sm form-control">
                                    <div class="divider"></div>
                                    <select class="mb-2 form-control">
                                        <option>Default Select</option>
                                    </select>
                                    <select class="form-control-sm form-control">
                                        <option>Small Select</option>
                                    </select>
                                </form>
                            </div>
                        </div>
                        <div class="main-card mb-3 card">
                            <div class="card-body">
                                <h5 class="card-title">Checkboxes &amp; Radios</h5>
                                <form class="">
                                    <fieldset class="position-relative form-group">
                                        <div class="position-relative form-check">
                                            <label class="form-check-label">
                                                <input name="radio1" type="radio" class="form-check-input"> 
                                                Option one is this and that—be sure to include why it's great
                                            </label>
                                        </div>
                                        <div class="position-relative form-check">
                                            <label class="form-check-label">
                                                <input name="radio1" type="radio" class="form-check-input"> 
                                                Option two can be something else and selecting it will deselect option one
                                            </label>
                                        </div>
                                        <div class="position-relative form-check disabled">
                                            <label class="form-check-label">
                                                <input name="radio1" disabled="" type="radio" class="form-check-input"> Option three is disabled
                                            </label>
                                        </div>
                                    </fieldset>
                                    <div class="position-relative form-check">
                                        <label class="form-check-label">
                                            <input type="checkbox" class="form-check-input"> Check me out
                                        </label>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="main-card mb-3 card">
                                <div class="card-body">
                                    <h5 class="card-title">Toggle Switch</h5>
                                    <div class="custom-control custom-switch mb-2">
                                        <input type="checkbox" class="custom-control-input" id="csw-basic-off">
                                        <label class="custom-control-label" for="csw-basic-off">Off</label>
                                    </div>
                                    <div class="custom-control custom-switch">
                                        <input type="checkbox" class="custom-control-input" id="csw-basic-on" checked>
                                        <label class="custom-control-label" for="csw-basic-on">On</label>
                                    </div>
                                </div>
                            </div>
                            <div class="main-card mb-3 card">
                                <div class="card-body">
                                    <h5 class="card-title">Toggle Switch Sizing</h5>
                                    <div class="custom-control custom-switch custom-switch-lg mb-3">
                                        <input type="checkbox" class="custom-control-input" id="csw-lg" checked>
                                        <label class="custom-control-label" for="csw-lg">Large</label>
                                    </div>
                                    <div class="custom-control custom-switch mb-3">
                                        <input type="checkbox" class="custom-control-input" id="csw-normal" checked>
                                        <label class="custom-control-label" for="csw-normal">Normal</label>
                                    </div>
                                    <div class="custom-control custom-switch custom-switch-sm">
                                        <input type="checkbox" class="custom-control-input" id="csw-sm" checked>
                                        <label class="custom-control-label" for="csw-sm">Small</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="main-card mb-3 card">
                                <div class="card-body">
                                    <h5 class="card-title">Toggle Switch Disabled</h5>
                                    <div class="custom-control custom-switch mb-2">
                                        <input type="checkbox" class="custom-control-input" id="csw-dis-off" disabled>
                                        <label class="custom-control-label" for="csw-dis-off">Disabled off</label>
                                    </div>
                                    <div class="custom-control custom-switch">
                                        <input type="checkbox" class="custom-control-input" id="csw-dis-on" disabled checked>
                                        <label class="custom-control-label" for="csw-dis-on">Disabled on</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="main-card mb-3 card">
                                <div class="card-body">
                                    <h5 class="card-title">Toggle Switch Inline</h5>
                                    <div class="d-flex align-items-center flex-wrap" style="gap: 1.5rem;">
                                        <div class="custom-control custom-switch">
                                            <input type="checkbox" class="custom-control-input" id="csw-inline1" checked>
                                            <label class="custom-control-label" for="csw-inline1">Enabled on</label>
                                        </div>
                                        <div class="custom-control custom-switch">
                                            <input type="checkbox" class="custom-control-input" id="csw-inline2">
                                            <label class="custom-control-label" for="csw-inline2">Enabled off</label>
                                        </div>
                                        <div class="custom-control custom-switch">
                                            <input type="checkbox" class="custom-control-input" id="csw-inline3" disabled>
                                            <label class="custom-control-label" for="csw-inline3">Disabled off</label>
                                        </div>
                                        <div class="custom-control custom-switch">
                                            <input type="checkbox" class="custom-control-input" id="csw-inline4" disabled checked>
                                            <label class="custom-control-label" for="csw-inline4">Disabled on</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="tab-pane tabs-animation fade" id="tab-content-1" role="tabpanel">
                <div class="row">
                    <div class="col-md-6">

                        <!-- Button Right -->
                        <div class="main-card mb-3 card">
                            <div class="card-body">
                                <h5 class="card-title">Input Group Button right</h5>
                                <div class="form-group mb-0">
                                    <label>Label</label>
                                    <div class="ig-group">
                                        <input type="text" class="ig-group__field ig-group__field--left" placeholder="Placeholder">
                                        <button class="ig-group__btn ig-group__btn--right">Button</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Button Left -->
                        <div class="main-card mb-3 card">
                            <div class="card-body">
                                <h5 class="card-title">Input Group Button left</h5>
                                <div class="form-group mb-0">
                                    <label>Label</label>
                                    <div class="ig-group">
                                        <button class="ig-group__btn ig-group__btn--left">Button</button>
                                        <input type="text" class="ig-group__field ig-group__field--right" placeholder="Placeholder">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Button Dropdown -->
                        <div class="main-card mb-3 card">
                            <div class="card-body">
                                <h5 class="card-title">Input Group Button dropdown</h5>
                                <div class="form-group mb-0">
                                    <label>Label</label>
                                    <div class="ig-group">
                                        <button class="ig-group__btn ig-group__btn--left ig-group__btn--dropdown">
                                            Button
                                            <span class="material-symbols-rounded">arrow_drop_down</span>
                                        </button>
                                        <input type="text" class="ig-group__field ig-group__field--right" placeholder="Seleccioná una opción">
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                    <div class="col-md-6">

                        <!-- Button Right — Mobile -->
                        <div class="main-card mb-3 card">
                            <div class="card-body">
                                <h5 class="card-title">Input Group Button right <small class="text-muted">mobile</small></h5>
                                <div class="form-group-sm mb-0">
                                    <label>Label</label>
                                    <div class="ig-group ig-group--sm">
                                        <input type="text" class="ig-group__field ig-group__field--left" placeholder="Placeholder">
                                        <button class="ig-group__btn ig-group__btn--right">Button</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Button Left — Mobile -->
                        <div class="main-card mb-3 card">
                            <div class="card-body">
                                <h5 class="card-title">Input Group Button left <small class="text-muted">mobile</small></h5>
                                <div class="form-group-sm mb-0">
                                    <label>Label</label>
                                    <div class="ig-group ig-group--sm">
                                        <button class="ig-group__btn ig-group__btn--left">Button</button>
                                        <input type="text" class="ig-group__field ig-group__field--right" placeholder="Placeholder">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Button Dropdown — Mobile -->
                        <div class="main-card mb-3 card">
                            <div class="card-body">
                                <h5 class="card-title">Input Group Button dropdown <small class="text-muted">mobile</small></h5>
                                <div class="form-group-sm mb-0">
                                    <label>Label</label>
                                    <div class="ig-group ig-group--sm">
                                        <button class="ig-group__btn ig-group__btn--left ig-group__btn--dropdown">
                                            Button
                                            <span class="material-symbols-rounded">arrow_drop_down</span>
                                        </button>
                                        <input type="text" class="ig-group__field ig-group__field--right" placeholder="Seleccioná una opción">
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
            <div class="tab-pane tabs-animation fade" id="tab-content-2" role="tabpanel">
                <form class="">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="main-card mb-3 card">
                                <div class="card-body">
                                    <h5 class="card-title">Checkboxes</h5>
                                    <div class="position-relative form-group">
                                        <div>
                                            <div class="custom-checkbox custom-control">
                                                <input type="checkbox" id="exampleCustomCheckbox" class="custom-control-input">
                                                <label class="custom-control-label" for="exampleCustomCheckbox">Check this custom checkbox</label>
                                            </div>
                                            <div class="custom-checkbox custom-control">
                                                <input type="checkbox" id="exampleCustomCheckbox2" class="custom-control-input">
                                                <label class="custom-control-label" for="exampleCustomCheckbox2">Or this one</label>
                                            </div>
                                            <div class="custom-checkbox custom-control">
                                                <input type="checkbox" id="exampleCustomCheckbox3" disabled="" class="custom-control-input">
                                                <label class="custom-control-label" for="exampleCustomCheckbox3">But not this disabled one</label>
                                             </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="main-card mb-3 card">
                                <div class="card-body">
                                    <h5 class="card-title">Inline</h5>
                                    <div class="position-relative form-group">
                                        <div>
                                            <div class="custom-checkbox custom-control custom-control-inline">
                                                <input type="checkbox" id="exampleCustomInline" class="custom-control-input">
                                                <label class="custom-control-label" for="exampleCustomInline">An inline custom input</label>
                                            </div>
                                            <div class="custom-checkbox custom-control custom-control-inline">
                                                <input type="checkbox" id="exampleCustomInline2" class="custom-control-input">
                                                <label class="custom-control-label" for="exampleCustomInline2">and another one</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="main-card mb-3 card">
                                <div class="card-body">
                                    <h5 class="card-title">Radios</h5>
                                    <div class="position-relative form-group">
                                        <div>
                                            <div class="custom-radio custom-control">
                                                <input type="radio" id="exampleCustomRadio" name="customRadio" class="custom-control-input">
                                                <label class="custom-control-label" for="exampleCustomRadio">Select this custom radio</label>
                                            </div>
                                            <div class="custom-radio custom-control">
                                                <input type="radio" id="exampleCustomRadio2" name="customRadio" class="custom-control-input">
                                                <label class="custom-control-label" for="exampleCustomRadio2">Or this one</label>
                                            </div>
                                            <div class="custom-radio custom-control">
                                                <input type="radio" id="exampleCustomRadio3" disabled="" class="custom-control-input">
                                                <label class="custom-control-label" for="exampleCustomRadio3">But not this disabled one</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
    {{> AppFooter/footer }}
</div>
<script>
(function(){
  // tpl-select: captura en fase capturing (antes de stopPropagation de Bootstrap)
  document.addEventListener('click', function(e){
    var item = e.target.closest('.tpl-select__item');
    if (!item) return;
    var wrapper = item.closest('.tpl-select');
    if (!wrapper) return;
    var valueEl = wrapper.querySelector('.tpl-select__value');
    if (!valueEl) return;
    valueEl.textContent = item.textContent.trim();
    valueEl.classList.remove('tpl-select__value--ph');
    wrapper.querySelectorAll('.tpl-select__item').forEach(function(i){ i.classList.remove('active'); });
    item.classList.add('active');
    var toggle = wrapper.querySelector('[data-toggle="dropdown"]');
    if (toggle) $(toggle).dropdown('hide');
  }, true);

  // select-multiple: cerrar al click fuera
  document.addEventListener('click',function(e){
    if(e.target.closest('.select-multiple__trigger')||e.target.closest('.select-multiple__item'))return;
    document.querySelectorAll('.select-multiple__dropdown.is-open').forEach(function(d){
      var w=d.closest('.select-multiple');
      d.classList.remove('is-open');
      w.querySelector('.select-multiple__trigger').classList.remove('is-open');
    });
  });
  document.addEventListener('click',function(e){
    var t=e.target.closest('.select-multiple__trigger');
    if(!t)return;
    var w=t.closest('.select-multiple');
    var d=w.querySelector('.select-multiple__dropdown');
    t.classList.toggle('is-open');
    d.classList.toggle('is-open');
  });
  document.addEventListener('click',function(e){
    var item=e.target.closest('.select-multiple__item');
    if(!item)return;
    var cb=item.querySelector('.select-multiple__checkbox');
    cb.classList.toggle('is-checked');
    var w=item.closest('.select-multiple');
    var ph=w.querySelector('.select-multiple__placeholder');
    var checked=w.querySelectorAll('.select-multiple__checkbox.is-checked');
    if(!checked.length){ph.textContent=ph.dataset.placeholder||'Seleccioná una opción';ph.classList.remove('has-value');}
    else{ph.textContent=Array.from(checked).map(function(c){return c.closest('.select-multiple__item').querySelector('.select-multiple__item-label').textContent;}).join(', ');ph.classList.add('has-value');}
  });
})();
</script>
{{/ base }}