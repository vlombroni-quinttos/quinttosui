{{#> base }}
{{> AppSidebar/sidebar foundations-radius=this }}
<div class="app-main__outer">
    <div class="app-main__inner">
        {{> AppMain/page-title }}

        <div class="row">
            <div class="col-12">
                <div class="main-card mb-3 card">
                    <div class="card-body">

                        <!-- ── Radius scale ───────────────────────────────── -->
                        <div class="foundations-section">
                            <div class="foundations-section__title">Corner Radius</div>

                            <div class="radius-scale">

                                <div class="radius-tile">
                                    <div class="radius-tile__box" style="border-radius:4px;"></div>
                                    <div class="radius-tile__label">Radius-xs</div>
                                    <div class="radius-tile__value">Value: 4px</div>
                                </div>

                                <div class="radius-tile">
                                    <div class="radius-tile__box" style="border-radius:8px;"></div>
                                    <div class="radius-tile__label">Radius-s</div>
                                    <div class="radius-tile__value">Value: 8px</div>
                                </div>

                                <div class="radius-tile">
                                    <div class="radius-tile__box" style="border-radius:16px;"></div>
                                    <div class="radius-tile__label">Radius-m</div>
                                    <div class="radius-tile__value">Value: 16px</div>
                                </div>

                                <div class="radius-tile">
                                    <div class="radius-tile__box" style="border-radius:24px;"></div>
                                    <div class="radius-tile__label">Radius-l</div>
                                    <div class="radius-tile__value">Value: 24px</div>
                                </div>

                                <div class="radius-tile">
                                    <div class="radius-tile__box" style="border-radius:32px;"></div>
                                    <div class="radius-tile__label">Radius-xl</div>
                                    <div class="radius-tile__value">Value: 32px</div>
                                </div>

                                <div class="radius-tile">
                                    <div class="radius-tile__box" style="border-radius:48px;"></div>
                                    <div class="radius-tile__label">Radius-2xl</div>
                                    <div class="radius-tile__value">Value: 48px</div>
                                </div>

                                <div class="radius-tile">
                                    <div class="radius-tile__box" style="border-radius:999px;"></div>
                                    <div class="radius-tile__label">Radius-Full</div>
                                    <div class="radius-tile__value">Value: 999px</div>
                                </div>

                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
    {{> AppFooter/footer }}
</div>
{{/ base }}
