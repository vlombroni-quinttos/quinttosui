{{#> base }}
{{> AppSidebar/sidebar elements-icons=this }}
<div class="app-main__outer">
    <div class="app-main__inner">
        {{> AppMain/page-title }}

        <div class="row">
            <div class="col-12">

                <!-- ── Config bar ──────────────────────────────────────────── -->
                <div class="icon-config-bar">
                    <span class="icon-config-bar__label">Configuración activa</span>
                    <div class="icon-config-bar__chips">
                        <span class="icon-config-bar__chip">
                            <span class="material-symbols-rounded">rounded_corner</span>
                            Rounded
                        </span>
                        <span class="icon-config-bar__chip">
                            <span class="material-symbols-rounded">line_weight</span>
                            Weight 300
                        </span>
                        <span class="icon-config-bar__chip">
                            <span class="material-symbols-rounded">format_color_fill</span>
                            Fill off
                        </span>
                        <span class="icon-config-bar__chip">
                            <span class="material-symbols-rounded">grade</span>
                            Grade normal
                        </span>
                        <span class="icon-config-bar__chip">
                            <span class="material-symbols-rounded">pageview</span>
                            Optical size 24dp
                        </span>
                    </div>
                </div>

                <!-- ── Notice ──────────────────────────────────────────────── -->
                <div class="icon-notice">
                    <span class="material-symbols-rounded icon-notice__icon">warning</span>
                    <div class="icon-notice__body">
                        <strong>Solo se puede usar esta librería de íconos.</strong>
                        Si no encontrás el ícono que necesitás, no uses una librería alternativa — contactá al equipo de producto para que lo agregue a la configuración oficial.
                    </div>
                </div>

                <!-- ── Navegación ──────────────────────────────────────────── -->
