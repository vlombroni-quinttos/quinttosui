                    <div class="card-body">
                        <h5 class="card-title">Navegación</h5>
                        <div class="icon-grid">
                            <div class="icon-item"><span class="material-symbols-rounded">home</span><span class="icon-item__name">home</span></div>
                            <div class="icon-item"><span class="material-symbols-rounded">menu</span><span class="icon-item__name">menu</span></div>
                            <div class="icon-item"><span class="material-symbols-rounded">close</span><span class="icon-item__name">close</span></div>
                            <div class="icon-item"><span class="material-symbols-rounded">arrow_back</span><span class="icon-item__name">arrow_back</span></div>
                            <div class="icon-item"><span class="material-symbols-rounded">arrow_forward</span><span class="icon-item__name">arrow_forward</span></div>
                            <div class="icon-item"><span class="material-symbols-rounded">chevron_left</span><span class="icon-item__name">chevron_left</span></div>
                            <div class="icon-item"><span class="material-symbols-rounded">chevron_right</span><span class="icon-item__name">chevron_right</span></div>
