<script>
// ── DWC Segmented button — multiselect toggle ─────────────────────────────────
// Vanilla JS: no depende de jQuery (el bundle carga después de este inline script)
document.addEventListener('click', function (e) {
  var item = e.target.closest('[data-multiselect] .dwc-seg-item');
  if (!item) return;
  if (item.classList.contains('dwc-seg-item--active')) {
    item.classList.remove('dwc-seg-item--active');
    item.classList.add('dwc-seg-item--inactive');
  } else {
    item.classList.remove('dwc-seg-item--inactive');
    item.classList.add('dwc-seg-item--active');
  }
});
</script>

