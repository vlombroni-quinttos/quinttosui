<script>
// Todo el código de inicialización se ejecuta en window 'load'
// para garantizar que jQuery y Bootstrap estén disponibles
// (webpack inyecta los scripts externos DESPUÉS del inline en el HTML compilado)
window.addEventListener('load', function () {

// ── Smart positioning de dropdowns ───────────────────────────────────────────
// Bootstrap 4 usa jQuery events → hay que escuchar con $(document).on()
// Popper.js (cargado por Bootstrap) aplica `inset` y `transform:translateY`
// que interfieren con el posicionamiento manual. Los anulamos usando
// setProperty(..., 'important') para ganar la cascada CSS en todos los casos.
// El trigger NUNCA queda tapado: el menú abre arriba o abajo según espacio.
(function () {
    var GAP = 4;

    // Función principal de posicionamiento
    function applyPosition(toggle) {
        var dropdown = toggle.closest('.dropdown');
        if (!dropdown) return;
        var menu = dropdown.querySelector('.dropdown-menu');
        if (!menu || !menu.classList.contains('show')) return;

        var rect = toggle.getBoundingClientRect();
        // Si el trigger aún no tiene layout (ej: tab recién activada), reintentar
        if (rect.width === 0 || rect.height === 0) {
            setTimeout(function () { applyPosition(toggle); }, 50);
            return;
        }

        var menuH = menu.scrollHeight;
        var menuW = rect.width;
        var spaceBelow = window.innerHeight - rect.bottom - GAP;
        var spaceAbove = rect.top - GAP;
        var goUp = spaceBelow < Math.min(menuH, 260) && spaceAbove > spaceBelow;

        var left = rect.left;
        if (menu.classList.contains('dropdown-menu-right')) left = rect.right - menuW;
        left = Math.max(8, Math.min(left, window.innerWidth - menuW - 8));

        // Usa setProperty !important para ganarle a Popper.js
        // (que setea inline `inset` + `transform:translateY` con mayor prioridad)
        var sp = function (p, v) { menu.style.setProperty(p, v, 'important'); };
        sp('position',   'fixed');
        sp('z-index',    '9999');
        sp('width',      menuW + 'px');
        sp('min-width',  '160px');
        sp('left',       left + 'px');
        sp('right',      'auto');
        sp('transform',  'none');   // cancela el translateY de Popper
        sp('inset',      'unset');  // cancela el shorthand inset de Popper

        if (goUp) {
            sp('top',    'auto');
            sp('bottom', (window.innerHeight - rect.top + GAP) + 'px');
            menu.setAttribute('x-placement', 'top-start');
        } else {
            sp('top',    (rect.bottom + GAP) + 'px');
            sp('bottom', 'auto');
            menu.setAttribute('x-placement', 'bottom-start');
        }
    }

    // Al abrirse: doble RAF para correr después del render cycle de Bootstrap/Popper
    $(document).on('shown.bs.dropdown', function (e) {
        var toggle = e.relatedTarget;
        if (!toggle) return;
        requestAnimationFrame(function () {
            requestAnimationFrame(function () {
                applyPosition(toggle);
                // Segundo pase a 100ms por si Popper hace ajustes tardíos
                setTimeout(function () { applyPosition(toggle); }, 100);
            });
        });
    });

    // Al cerrarse: limpiar todos los estilos inline para que el próximo open parta limpio
    $(document).on('hidden.bs.dropdown', function (e) {
        var menu = e.target.querySelector('.dropdown-menu');
        if (menu) {
            menu.removeAttribute('style');
            menu.removeAttribute('x-placement');
        }
    });

    // Reposicionar si el usuario scrollea o redimensiona con el menú abierto
    $(window).on('scroll.tplDropdown resize.tplDropdown', function () {
        var open = document.querySelector('[data-toggle="dropdown"][aria-expanded="true"]');
        if (open) applyPosition(open);
    });
})();

// ── Comportamiento de los tpl-select: actualiza el valor visible al elegir una opción.
// Usamos fase de CAPTURA porque Bootstrap 4 llama stopPropagation() en el dropdown-menu
// durante el bubble, cortando el evento antes de que llegue al document.
(function () {
    document.addEventListener('click', function (e) {
        var item = e.target.closest('.tpl-select__item');
        if (!item) return;
        var select = item.closest('.tpl-select');
        if (!select) return;
        var valueEl = select.querySelector('.tpl-select__value');
        valueEl.textContent = item.textContent.trim();
        // Si el ítem no tiene data-value lo tratamos como placeholder
        if (!item.dataset.value) {
            valueEl.classList.add('tpl-select__value--ph');
        } else {
            valueEl.classList.remove('tpl-select__value--ph');
        }
        // Marca el ítem seleccionado como activo
        select.querySelectorAll('.tpl-select__item').forEach(function (i) {
            i.classList.remove('active');
        });
        item.classList.add('active');
    }, true); // true = capture phase, corre antes del stopPropagation de Bootstrap
}());


}); // end window load
</script>
