{{#> base }}
{{> AppSidebar/sidebar apps-templates-tables=this }}
<div class="app-main__outer">
    <div class="app-main__inner">
        {{> AppMain/page-title }}

        <!-- Tab nav -->
        <ul class="tab-nav nav" role="tablist">
            <li class="nav-item">
                <a data-toggle="tab" href="#tab-tables" class="nav-link active">Tablas</a>
            </li>
            <li class="nav-item">
                <a data-toggle="tab" href="#tab-forms" class="nav-link">Formularios</a>
            </li>
            <li class="nav-item">
                <a data-toggle="tab" href="#tab-complex-forms" class="nav-link">Formularios Complejos</a>
            </li>
        </ul>

        <!-- Tab content -->
        <div class="tab-content">
            <div class="tab-pane active" id="tab-tables" role="tabpanel">

                <!-- ── Buscador ─────────────────────────────────────────── -->
                <div class="tpl-buscador">
                    <div class="tpl-table__header">
                        <h5 class="tpl-table__title">Buscador de [criterio]</h5>
                        <div class="tpl-buscador__btn-group">
                            <button class="ch__icon-btn" title="Configurar columnas">
                                <span class="material-symbols-rounded">tune</span>
                            </button>
                            <button class="ch__icon-btn" title="Ajustes">
                                <span class="material-symbols-rounded">settings</span>
                            </button>
                        </div>
                    </div>
                    <div class="tpl-buscador__body">
                        <div class="tpl-buscador__field">
                            <label class="tpl-buscador__label">Categoría</label>
                            <div class="dropdown tpl-select">
                                <button type="button" class="form-control tpl-select__trigger" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                    <span class="tpl-select__value tpl-select__value--ph">Seleccionar</span>
                                    <span class="material-symbols-rounded tpl-select__chevron">arrow_drop_down</span>
                                </button>
                                <div class="dropdown-menu tpl-select__menu">
                                    <button type="button" class="dropdown-item tpl-select__item" data-value="admin">Administración</button>
                                    <button type="button" class="dropdown-item tpl-select__item" data-value="ventas">Ventas</button>
                                    <button type="button" class="dropdown-item tpl-select__item" data-value="marketing">Marketing</button>
                                    <button type="button" class="dropdown-item tpl-select__item" data-value="soporte">Soporte</button>
                                    <button type="button" class="dropdown-item tpl-select__item" data-value="finanzas">Finanzas</button>
                                </div>
                            </div>
                        </div>
                        <div class="tpl-buscador__field">
                            <label class="tpl-buscador__label">Estado</label>
                            <div class="dropdown tpl-select">
                                <button type="button" class="form-control tpl-select__trigger" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                    <span class="tpl-select__value tpl-select__value--ph">Todos</span>
                                    <span class="material-symbols-rounded tpl-select__chevron">arrow_drop_down</span>
                                </button>
                                <div class="dropdown-menu tpl-select__menu">
                                    <button type="button" class="dropdown-item tpl-select__item" data-value="activo">Activo</button>
                                    <button type="button" class="dropdown-item tpl-select__item" data-value="inactivo">Inactivo</button>
                                    <button type="button" class="dropdown-item tpl-select__item" data-value="pendiente">Pendiente</button>
                                </div>
                            </div>
                        </div>
                        <div class="tpl-buscador__field">
                            <label class="tpl-buscador__label">Fecha desde</label>
                            <div class="qdp-field">
                                <div class="form-control qdp-field__input" tabindex="0" role="button" aria-haspopup="true" aria-expanded="false">
                                    <span class="qdp-field__value">dd/mm/aaaa</span>
                                    <span class="material-symbols-rounded">calendar_today</span>
                                </div>
                                <div class="qdp" role="dialog" aria-label="Selector de fecha">
                                    <!-- Panel generado por JS -->
                                </div>
                            </div>
                        </div>
                        <div class="tpl-buscador__field">
                            <label class="tpl-buscador__label">Fecha hasta</label>
                            <div class="qdp-field">
                                <div class="form-control qdp-field__input" tabindex="0" role="button" aria-haspopup="true" aria-expanded="false">
                                    <span class="qdp-field__value">dd/mm/aaaa</span>
                                    <span class="material-symbols-rounded">calendar_today</span>
                                </div>
                                <div class="qdp" role="dialog" aria-label="Selector de fecha">
                                    <!-- Panel generado por JS -->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

